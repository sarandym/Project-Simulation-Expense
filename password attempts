set_password = int(input("set password: "))
password_attempts = 0
enter_password = 0
while True:
    enter_password = int(input('enter password: '))
    if enter_password == set_password:
        print("access granted")
        break
    else:
        print('error')
    password_attempts += 1

    if password_attempts == 3:
        print('no attempts left')
        break
